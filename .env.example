# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key（從 Google AI Studio 取得）
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive 根資料夾 ID（從資料夾網址取得，需已分享給服務帳戶）
# 例：https://drive.google.com/drive/folders/1A2B3C4D5E → ID 為 1A2B3C4D5E
GOOGLE_DRIVE_PARENT_ID=your_google_drive_folder_id_here

# Google 服務帳戶憑證 JSON（整個 JSON 檔案內容壓縮成單行）
# 範例：{"type":"service_account","project_id":"...","private_key_id":"...",...}
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
