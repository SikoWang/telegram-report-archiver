# Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive parent folder ID
# Example: https://drive.google.com/drive/folders/1A2B3C4D5E -> 1A2B3C4D5E
GOOGLE_DRIVE_PARENT_ID=your_google_drive_folder_id_here

# Preferred when service account key creation is disabled by organization policy.
# Create an OAuth Client ID and use a refresh token with Drive scope.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token

# Legacy option: only use this if your Google organization allows service account keys.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
